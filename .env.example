# Shared platform defaults
ENVIRONMENT=development
LOG_LEVEL=INFO

# API and frontend
FRONTEND_PORT=3000
API_GATEWAY_PORT=8000

# Data stores
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_ai
POSTGRES_USER=enterprise_ai
POSTGRES_PASSWORD=enterprise_ai
INGESTION_JOB_STORE_BACKEND=memory
INGESTION_PROCESSING_MODE=sync

REDIS_HOST=localhost
REDIS_PORT=6379
INGESTION_QUEUE_BACKEND=memory

VECTOR_STORE_BACKEND=qdrant
VECTOR_COLLECTION_NAME=document_chunks
VECTOR_EMBEDDING_FIELD=embedding
VECTOR_CONTENT_PAYLOAD_KEY=content
VECTOR_SOURCE_PAYLOAD_KEY=source
VECTOR_TENANT_PAYLOAD_KEY=tenant_id
RETRIEVAL_TOP_K=5
QDRANT_HOST=localhost
QDRANT_PORT=6333
MILVUS_HOST=localhost
MILVUS_PORT=19530

OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=enterprise-ai

# Auth
AUTH_ENABLED=false
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=enterprise-ai
KEYCLOAK_CLIENT_ID=enterprise-ai-web
KEYCLOAK_VERIFY_SSL=true

# Security
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
RATE_LIMIT_PER_MINUTE=60

# Internal service URLs
API_GATEWAY_BASE_URL=http://localhost:8000
CHAT_SERVICE_BASE_URL=http://localhost:8002
RAG_SERVICE_BASE_URL=http://localhost:8003
INGESTION_SERVICE_BASE_URL=http://localhost:8004
OCR_SERVICE_BASE_URL=http://localhost:8005
MODEL_ROUTER_BASE_URL=http://localhost:8006
EVAL_SERVICE_BASE_URL=http://localhost:8007
REQUEST_TIMEOUT_SECONDS=10.0
UPSTREAM_RETRY_COUNT=2

# Model backends
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8001
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=embeddinggemma

# Tracing
TRACING_ENABLED=false
OTLP_ENDPOINT=
